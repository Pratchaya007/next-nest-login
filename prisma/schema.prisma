generator client {
  provider     = "prisma-client"
  output       = "../src/database/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
  SUPERADMIN
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  password            String
  name                String    @db.VarChar(20)
  role                Role      @default(USER)
  avatarUrl           String?
  coverUrl            String?
  resetToken          String?
  resetTokenExpiresAt DateTime? @db.Timestamptz()
  refreshTokenHash    String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}
